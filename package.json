    "prepublish-check": "npm run build && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^28.1.0",
    "tsup": "^8.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  },
  "author": "InAI <contact@inai.dev>",
