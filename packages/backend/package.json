{
  "name": "@inai-dev/backend",
  "version": "0.1.0",
  "description": "Server-side InAI Auth client",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inai-dev/types": "^0.1.0",
    "@inai-dev/shared": "^0.1.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "InAI <contact@inai.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inai-dev/sdk.git",
    "directory": "packages/backend"
  },
  "homepage": "https://inai.dev/",
  "bugs": "https://github.com/inai-dev/sdk/issues",
  "keywords": ["inai", "auth", "backend", "server", "multi-tenant", "api-client"]
}
