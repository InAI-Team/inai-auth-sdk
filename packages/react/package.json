{
  "name": "@inai-dev/react",
  "version": "0.1.0",
  "description": "React components, hooks, and providers for InAI Auth",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inai-dev/types": "^0.1.0",
    "@inai-dev/shared": "^0.1.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "InAI <contact@inai.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/InAI-Team/inai-auth-sdk.git",
    "directory": "packages/react"
  },
  "homepage": "https://inai.dev/",
  "bugs": "https://github.com/InAI-Team/inai-auth-sdk/issues",
  "keywords": ["inai", "auth", "react", "hooks", "provider", "multi-tenant"]
}
