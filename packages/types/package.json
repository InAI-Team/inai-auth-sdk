{
  "name": "@inai-dev/types",
  "version": "1.1.0",
  "description": "TypeScript types for the InAI Auth SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "InAI <contact@inai.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/InAI-Team/inai-auth-sdk.git",
    "directory": "packages/types"
  },
  "homepage": "https://inai.dev/",
  "bugs": "https://github.com/InAI-Team/inai-auth-sdk/issues",
  "keywords": [
    "inai",
    "auth",
    "types",
    "typescript",
    "multi-tenant"
  ]
}
